# ── Secretary Agent Kit — secrets ──────────────────────────────
# Copy this file to ".env" and fill in. Never commit your real .env.

# 1) Your Telegram bot token, from @BotFather (we'll walk you through it)
TELEGRAM_BOT_TOKEN=

# 2) Your Claude API key, from console.anthropic.com
ANTHROPIC_API_KEY=
# Which Claude model the secretary "thinks" with.
#   claude-opus-4-8    → most capable, best at tricky scheduling (default)
#   claude-sonnet-4-6  → faster + cheaper, still very capable
CLAUDE_MODEL=claude-opus-4-8

# 3) Google OAuth (for Calendar + Gmail), from console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4322/oauth/callback

# Safety: when "true", the agent drafts actions and asks you before sending
# anything or booking anything. Start here. Set to "false" only when you trust it.
CONFIRM_BEFORE_SEND=true
